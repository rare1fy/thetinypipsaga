; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dice Hero"
config/description="竖屏 Roguelike 骰子构筑游戏 - Godot 版"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://common/autoload/game_manager.gd"
EventBus="*res://common/autoload/event_bus.gd"
SoundPlayer="*res://common/autoload/sound_player.gd"
GameData="*res://common/autoload/game_data.gd"

[display]

window/size/viewport_width=360
window/size/viewport_height=640
window/size/window_width_override=1080
window/size/window_height_override=1920
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
window/handheld/orientation=1

[dotnet]

project/assembly_name="Dice Hero"

[global]

class_name_hash={}

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
textures/canvas_textures/default_texture_filter=0

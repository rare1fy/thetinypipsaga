## 根据图标名获取数据
static func get_icon(name: String) -> Array:
	match name:
		"sword": return SWORD
		"skull": return SKULL
		"crown": return CROWN
		"shop_bag": return SHOP_BAG
		"question": return QUESTION
		"campfire": return CAMPFIRE
		"poison": return POISON
		"flame": return FLAME
		"shield": return SHIELD
		"heart": return HEART
		"coin": return COIN
		"zap": return ZAP
		"trophy": return TROPHY
		"dice": return DICE
		"play": return PLAY
		"refresh": return REFRESH
		_: return []
